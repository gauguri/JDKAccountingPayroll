# Copy to .env and fill in. Never commit .env.

# Database
POSTGRES_DB=jdkbooks
POSTGRES_USER=jdkbooks
POSTGRES_PASSWORD=change-me-to-a-strong-password
DATABASE_URL=postgresql+psycopg://jdkbooks:change-me-to-a-strong-password@db:5432/jdkbooks

# Auth / crypto
JWT_SECRET=generate-a-long-random-string
# 32-byte key (base64) used for field-level encryption of SSN / direct deposit / EIN
FIELD_ENCRYPTION_KEY=generate-a-32-byte-base64-key
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

# Document storage (local fs for dev; S3-compatible later)
DOCUMENT_STORAGE_PATH=/data/documents

# Optional AI assistant (read-only, suggestion-only). Leave blank to disable.
LLM_API_KEY=

# Optional integrations (later phases — leave blank for MVP 1)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
